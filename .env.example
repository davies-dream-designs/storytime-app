# Copy this file to .env.local and fill in values.
# Never commit real secrets to version control.

# Required: Anthropic API key for story generation
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required: Clerk auth — get these from https://clerk.com
# Create an app → API Keys tab
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs (defaults work for local dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Required: Vercel KV (Redis) — auto-added when you link a KV store in Vercel dashboard
# Project → Storage → Create Database → KV → Connect to Project
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Application
NODE_ENV=development
PORT=3000
