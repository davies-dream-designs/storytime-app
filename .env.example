# Copy this file to .env.local and fill in values.
# Never commit real secrets to version control.

# Application
NODE_ENV=development
PORT=3000

# Example: DATABASE_URL=postgresql://user:password@localhost:5432/mydb
# Example: NEXT_PUBLIC_API_URL=https://api.example.com

# Waitlist → Kit (kit.com, ex-ConvertKit). If KIT_API_KEY is set, signups
# are created as subscribers via the Kit v4 API; otherwise they append to a
# local .data/waitlist.jsonl file. KIT_TAG_ID is optional — set it to a Kit
# tag id to auto-tag waitlist signups so they're filterable.
# KIT_API_KEY=kit_xxxxxxxx
# KIT_TAG_ID=
