# Copy this file to .env.local and fill in values.
# Never commit real secrets to version control.

# Required: Anthropic API key for story generation
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required: Clerk auth — get these from https://clerk.com
# Create an app → API Keys tab
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs (defaults work for local dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Required: Vercel KV (Redis) — auto-added when you link a KV store in Vercel dashboard
# Project → Storage → Create Database → KV → Connect to Project
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Required: Stripe — get these from https://dashboard.stripe.com
# Secret key: Developers → API keys → Secret key
# Webhook secret: Developers → Webhooks → Add endpoint → storycot.com.au/api/stripe/webhook
# Events to listen for: checkout.session.completed
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Your app's public URL (used for Stripe redirect URLs)
# In production: https://storycot.com.au
# In local dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Application
NODE_ENV=development
PORT=3000

# E2E testing (Playwright) — see README Testing section
# These are for running tests against dev.storycot.com
PLAYWRIGHT_BASE_URL=https://dev.storycot.com
# Vercel deployment protection bypass — regenerate via Vercel MCP (expires ~23h)
VERCEL_BYPASS_URL=https://dev.storycot.com/?_vercel_share=your_bypass_token_here
# Clerk test user ID — get from Clerk dashboard after creating playwright test user
E2E_TEST_USER_ID=user_your_test_user_id_here

# Inngest — durable job queue for the print-book build pipeline.
# Local dev uses the Inngest dev server (npx inngest-cli dev) and needs neither key.
# In production, set both from the Inngest dashboard.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Print-book pipeline driver: "inngest" to use the durable Inngest queue,
# unset/anything else keeps the in-process after() continuation (default).
BOOK_PIPELINE_DRIVER=
