# Copy this file to .env.local and fill in values.
# Never commit real secrets to version control.

# Application
NODE_ENV=development
PORT=3000

# Example: DATABASE_URL=postgresql://user:password@localhost:5432/mydb
# Example: NEXT_PUBLIC_API_URL=https://api.example.com

# Waitlist → Loops (loops.so). If LOOPS_API_KEY is set, signups upsert a
# contact via the Loops API (userGroup "waitlist"); otherwise they append to
# a local .data/waitlist.jsonl file. LOOPS_MAILING_LIST_ID is optional — set
# it to a Loops mailing list id to subscribe signups to that list.
# LOOPS_API_KEY=xxxxxxxx
# LOOPS_MAILING_LIST_ID=
